# =============================================================================
# Equiterra — .gitignore
# PHP / MySQL / Docker / macOS / VS Code / JetBrains
# =============================================================================

# -----------------------------------------------------------------------------
# User uploads (runtime created data — never commit to repo)
# -----------------------------------------------------------------------------
app/uploads/
uploads/

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# PHP
# -----------------------------------------------------------------------------
vendor/
composer.lock

# -----------------------------------------------------------------------------
# Docker runtime
# -----------------------------------------------------------------------------
# Ignore local override files but keep the main compose file
docker-compose.override.yml

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/
*.code-workspace

# -----------------------------------------------------------------------------
# JetBrains (PhpStorm, IntelliJ)
# -----------------------------------------------------------------------------
.idea/
*.iml

# -----------------------------------------------------------------------------
# Logs & caches
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
cache/

# -----------------------------------------------------------------------------
# OS general
# -----------------------------------------------------------------------------
Thumbs.db
Desktop.ini